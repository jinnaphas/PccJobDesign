{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pccjobdesign/schema/competency_dict.schema.json",
  "title": "Competency Dictionary",
  "description": "The shared vocabulary that lets a JD's required levels (job_role.specs.competency_targets) and a person's rated levels (person.competencies) be compared on the same axis. Seeded from the JE 30-item framework so JD, candidate and employee all speak one language.",
  "type": "object",
  "required": ["version", "competencies"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string" },
    "scale": {
      "type": "object",
      "description": "Global rating scale (default 1-5 with anchors).",
      "additionalProperties": false,
      "properties": {
        "min": { "type": "integer" },
        "max": { "type": "integer" },
        "anchors": { "type": "object", "additionalProperties": { "type": "string" } }
      }
    },
    "competencies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name_en", "category"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "description": "Stable key used in JD targets and person ratings, e.g. 'technical_expertise'." },
          "name_en": { "type": "string" },
          "name_th": { "type": "string" },
          "category": { "type": "string", "enum": ["core", "managerial", "technical", "qualification"] },
          "je_items": { "type": "array", "items": { "type": "integer" }, "description": "JE dimension numbers this competency derives from." }
        }
      }
    }
  }
}
